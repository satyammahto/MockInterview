rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Resume uploads: user can only upload/read their own files
    match /resumes/{uid}/{allPaths=**} {
      // Allow authenticated users to upload to their own folder
      allow write: if request.auth != null
        && request.auth.uid == uid
        && request.resource.size < 5 * 1024 * 1024   // Max 5 MB
        && (request.resource.contentType == 'application/pdf'
            || request.resource.contentType == 'application/vnd.openxmlformats-officedocument.wordprocessingml.document');

      // Allow reads by the owner or by Cloud Functions (Admin SDK)
      allow read: if request.auth != null && request.auth.uid == uid;
    }

    // Deny all other paths
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
